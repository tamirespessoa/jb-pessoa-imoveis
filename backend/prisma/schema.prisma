generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
}

model Person {
  id               Int      @id @default(autoincrement())
  type             String
  fullName         String
  cpf              String?  @unique
  rg               String?
  phone            String?
  email            String?
  maritalStatus    String?
  profession       String?
  monthlyIncome    Float?
  fgtsBalance      Float?
  hasDependents    Boolean  @default(false)
  dependentsCount  Int      @default(0)
  addressZipCode   String?
  addressStreet    String?
  addressNumber    String?
  addressDistrict  String?
  addressCity      String?
  addressState     String?
  notes            String?

  company          String?
  commercialPhone  String?
  residentialPhone String?
  contactPhone     String?
  whatsapp         Boolean  @default(false)

  createdAt        DateTime @default(now())

  documents        Document[]
  propertiesOwned  Property[] @relation("OwnerProperties")
}

model Property {
  id               Int      @id @default(autoincrement())
  title            String
  code             String   @unique
  description      String?
  purpose          String?
  type             String?
  price            Float?
  condominiumFee   Float?
  iptuValue        Float?
  status           String?
  bedrooms         Int?
  bathrooms        Int?
  suites           Int?
  parkingSpaces    Int?
  builtArea        Float?
  landArea         Float?
  zipCode          String?
  street           String?
  number           String?
  district         String?
  city             String?
  state            String?
  ownerId          Int?
  createdAt        DateTime @default(now())

  owner            Person?  @relation("OwnerProperties", fields: [ownerId], references: [id])
  documents        Document[]
}

model Document {
  id         Int       @id @default(autoincrement())
  title      String
  type       String
  fileName   String
  filePath   String
  mimeType   String?
  personId   Int?
  propertyId Int?
  createdAt  DateTime  @default(now())

  person     Person?   @relation(fields: [personId], references: [id])
  property   Property? @relation(fields: [propertyId], references: [id])
}