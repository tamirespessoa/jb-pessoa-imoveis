// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Person {
  id                  String   @id @default(cuid())
  type                String   // CLIENTE_COMPRADOR, CLIENTE_ALUGUEL, PROPRIETARIO
  fullName            String
  cpf                 String?  @unique
  rg                  String?
  email               String?  @unique
  phone               String?
  company             String?
  commercialPhone     String?
  residentialPhone    String?
  contactPhone        String?
  whatsapp            String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  properties          Property[]
  clientAppointments  Appointment[] @relation("clientAppointments")
  documents           Document[]

  @@map("persons")
}

model Property {
  id            String   @id @default(cuid())
  title         String
  code          String   @unique
  type          String   // RESIDENCIAL, COMERCIAL, TERRENO, etc
  status        String   @default("DISPONIVEL") // DISPONIVEL, ALUGADO, VENDIDO
  price         Float
  rentPrice     Float?
  area          Float
  rooms         Int
  bathrooms     Int
  garage         Int?
  street        String
  number        String
  complement    String?
  zipCode       String
  district      String
  city          String
  state         String
  description   String?
  ownerId       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  owner         Person   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documents     Document[]
  appointments  Appointment[]

  @@index([ownerId])
  @@map("properties")
}

model Document {
  id         String   @id @default(cuid())
  fileName   String
  fileUrl    String
  fileType   String
  fileSize   Int
  personId   String?
  propertyId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  person     Person?   @relation(fields: [personId], references: [id], onDelete: Cascade)
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([personId])
  @@index([propertyId])
  @@map("documents")
}

model Appointment {
  id              String   @id @default(cuid())
  propertyId      String
  clientId        String
  appointmentDate DateTime
  duration        Int      @default(60)
  status          String   @default("AGENDADO") // AGENDADO, CONFIRMADO, CANCELADO, REALIZADO, NAO_COMPARECEU
  notes           String?
  outcome         String?  // INTERESSADO, NAO_INTERESSADO, PENDENTE
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property        Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  client          Person   @relation("clientAppointments", fields: [clientId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([clientId])
  @@map("appointments")
}