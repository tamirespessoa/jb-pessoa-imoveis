generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  GERENTE
  CORRETOR
  RECEPCIONISTA
  ANALISTA_CREDITO
  USER
}

enum PropertyStatus {
  DISPONIVEL
  RESERVADO
  EM_ANALISE
  VENDIDO
  LOCADO
  ARQUIVADO
}

enum LeadStatus {
  NOVO
  EM_ATENDIMENTO
  CONVERTIDO
  PERDIDO
}

enum ConversationStatus {
  ABERTA
  EM_ATENDIMENTO
  FINALIZADA
}

enum PortalIntegrationType {
  MANUAL
  XML
  API
}

enum PortalPublicationStatus {
  PENDENTE
  PUBLICADO
  ATUALIZADO
  ERRO
  REMOVIDO
}

enum MediaType {
  IMAGE
  VIDEO
  TOUR_360
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(USER)
  online    Boolean  @default(false)
  active    Boolean  @default(true)
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads         Lead[]         @relation("LeadAssignedTo")
  conversations Conversation[] @relation("ConversationAssignedTo")
  auditLogs     AuditLog[]

  @@index([role])
  @@index([online])
  @@map("users")
}

model Person {
  id               String   @id @default(cuid())
  type             String
  fullName         String
  cpf              String?  @unique
  rg               String?
  email            String?  @unique
  phone            String?
  company          String?
  commercialPhone  String?
  residentialPhone String?
  contactPhone     String?
  whatsapp         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  properties   Property[]
  documents    Document[]
  appointments Appointment[]
  proposals    Proposal[]

  @@index([type])
  @@index([fullName])
  @@map("persons")
}

model Property {
  id          String         @id @default(cuid())
  title       String
  code        String?        @unique
  description String?
  price       Float?
  rentPrice   Float?
  promoPrice  Float?
  type        String?
  category    String?        @default("Normal")
  purpose     String?        @default("Residencial")
  status      PropertyStatus @default(DISPONIVEL)

  street           String?
  number           String?
  complement       String?
  block            String?
  apartment        String?
  zipCode          String?
  district         String?
  officialDistrict String?
  city             String?
  state            String?
  country          String? @default("Brasil")

  area        Float?
  builtArea   Float?
  usableArea  Float?
  totalArea   Float?
  rooms       Int?
  suites      Int?
  bathrooms   Int?
  garage      Int?
  livingRooms Int?
  floor       String?

  furnished Boolean @default(false)
  financed  Boolean @default(false)
  exchange  Boolean @default(false)

  publishOnSite      Boolean @default(true)
  siteHighlight      Boolean @default(false)
  publishOnPortals   Boolean @default(false)
  highlightOnPortals Boolean @default(false)
  valueOnRequest     Boolean @default(false)
  negotiable         Boolean @default(false)

  internalDescription String?
  captorName          String?

  images     Json?
  coverImage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownerId String?
  owner   Person? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  documents          Document[]
  proposals          Proposal[]
  medias             PropertyMedia[]
  portalPublications PropertyPortalPublication[]

  @@index([status])
  @@index([type])
  @@index([city])
  @@index([district])
  @@index([publishOnSite])
  @@index([publishOnPortals])
  @@map("properties")
}

model PropertyMedia {
  id          String    @id @default(cuid())
  type        MediaType @default(IMAGE)
  url         String
  description String?
  isPrimary   Boolean   @default(false)
  publish     Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([isPrimary])
  @@index([publish])
  @@map("property_medias")
}

model Document {
  id        String   @id @default(cuid())
  title     String
  type      String
  filePath  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personId   String?
  propertyId String?

  person   Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([personId])
  @@index([propertyId])
  @@map("documents")
}

model Appointment {
  id        String   @id @default(cuid())
  date      DateTime
  notes     String?
  status    String   @default("AGENDADO")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId String?
  client   Person? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([clientId])
  @@map("appointments")
}

model Proposal {
  id        String   @id @default(cuid())
  value     Float
  status    String   @default("PENDENTE")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientId   String?
  propertyId String?

  client   Person?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([propertyId])
  @@index([status])
  @@map("proposals")
}

model PropertyRequest {
  id           String   @id @default(cuid())
  ownerName    String?
  name         String?
  email        String?
  phone        String?
  whatsapp     String?
  propertyType String?
  address      String?
  city         String?
  state        String?
  message      String?
  status       String   @default("NOVO")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("property_requests")
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  email     String?
  phone     String?
  message   String?
  source    String?
  status    LeadStatus @default(NOVO)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  assignedToId String?
  assignedTo   User?   @relation("LeadAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  conversations Conversation[]

  @@index([status])
  @@index([source])
  @@index([assignedToId])
  @@map("leads")
}

model LeadDistribution {
  id         String   @id @default(cuid())
  brokerId   String?
  brokerName String?
  active     Boolean  @default(true)
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([active])
  @@index([position])
  @@map("lead_distribution")
}

model Conversation {
  id        String             @id @default(cuid())
  status    ConversationStatus @default(ABERTA)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation("ConversationAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  messages Message[]

  @@index([status])
  @@index([leadId])
  @@index([assignedToId])
  @@map("conversations")
}

model Message {
  id        String   @id @default(cuid())
  text      String
  sender    String
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model Portal {
  id              String                @id @default(cuid())
  name            String
  slug            String?               @unique
  active          Boolean               @default(true)
  integrationType PortalIntegrationType @default(MANUAL)
  apiUrl          String?
  apiKey          String?
  xmlUrl          String?
  lastSync        DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  publications PropertyPortalPublication[]

  @@index([active])
  @@index([integrationType])
  @@map("portals")
}

model PropertyPortalPublication {
  id           String                  @id @default(cuid())
  status       PortalPublicationStatus @default(PENDENTE)
  externalCode String?
  externalUrl  String?
  lastSync     DateTime?
  error        String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  propertyId String
  portalId   String

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  portal   Portal   @relation(fields: [portalId], references: [id], onDelete: Cascade)

  logs PortalSyncLog[]

  @@unique([propertyId, portalId])
  @@index([status])
  @@index([propertyId])
  @@index([portalId])
  @@map("property_portal_publications")
}

model PortalSyncLog {
  id        String   @id @default(cuid())
  message   String
  success   Boolean
  payload   Json?
  response  Json?
  createdAt DateTime @default(now())

  publicationId String
  publication   PropertyPortalPublication @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@index([publicationId])
  @@index([success])
  @@index([createdAt])
  @@map("portal_sync_logs")
}

model CompanySettings {
  id          String   @id @default(cuid())
  name        String
  tradingName String?
  cnpj        String?
  phone       String?
  whatsapp    String?
  email       String?
  website     String?
  address     String?
  city        String?
  state       String?
  zipCode     String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("company_settings")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ip        String?
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}
